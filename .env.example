# Host port published by Docker Compose.
ZOHO_APP_PORT=8765

# Absolute path to the SQLite database file on the host machine.
ZOHO_DB_PATH_HOST="/absolute/path/to/zoho_data_work/data/zoho.sqlite3"

# Absolute path to the directory that contains the attachment ZIP archives.
ZOHO_BACKUP_DIR_HOST="/absolute/path/to/zoho_data_work/zoho backup"
